---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';

const allProtocols = await getCollection('protocols', ({ data }) => !data.draft);
const sorted = [...allProtocols].sort((a, b) =>
  new Date(b.data.updated).getTime() - new Date(a.data.updated).getTime()
);

// Dynamic tags — count frequency across all protocols
const tagFreq: Record<string, number> = {};
for (const p of allProtocols) {
  for (const tag of p.data.tags) {
    tagFreq[tag] = (tagFreq[tag] ?? 0) + 1;
  }
}
const popularTags = Object.entries(tagFreq)
  .sort((a, b) => b[1] - a[1])
  .slice(0, 15)
  .map(([tag, count]) => ({ tag, count }));

const evidenceLabels: Record<string, string> = {
  'strong': '4/4',
  'moderate': '3/4',
  'preliminary': '2/4',
  'expert-opinion': '1/4',
};
---

<Base title="CiteThis" description="Evidence-based research syntheses. Original protocols that don't exist elsewhere.">

  <!-- Hero -->
  <section style="padding: 3rem 0 2rem; text-align: center;">
    <h1 style="font-size: clamp(2.5rem, 8vw, 4rem); font-weight: 900; letter-spacing: -0.03em; margin-bottom: 0.75rem; color: var(--text);">
      CiteThis
    </h1>
    <p style="font-size: 1.1rem; color: var(--text-muted); max-width: 36rem; margin: 0 auto 2.5rem;">
      Evidence-based research syntheses.<br />
      Original protocols that don't exist elsewhere.
    </p>

    <!-- Search — prominent, centered -->
    <div id="search" style="max-width: 40rem; margin: 0 auto 1.5rem;"></div>

    <!-- Dynamic tags -->
    <div style="display: flex; flex-wrap: wrap; justify-content: center; gap: 0.5rem; max-width: 36rem; margin: 0 auto;">
      {popularTags.map(({ tag, count }) => (
        <a
          href={`/tags/${tag}`}
          style={`text-decoration: none; font-family: monospace; font-size: 0.8rem; padding: 0.2rem 0.6rem; border: 1px solid var(--border); color: var(--text-muted); border-radius: 2px;`}
          title={`${count} protocol${count !== 1 ? 's' : ''}`}
        >
          #{tag}
        </a>
      ))}
    </div>
  </section>

  <!-- Protocols grid -->
  <section style="border-top: 1px solid var(--border); padding-top: 2.5rem; margin-top: 1rem;">
    <div style="display: flex; align-items: baseline; justify-content: space-between; margin-bottom: 1.5rem;">
      <h2 style="font-family: monospace; font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.12em; color: var(--text-muted);">
        Protocols ({allProtocols.length})
      </h2>
      <div style="display: flex; gap: 1rem; font-family: monospace; font-size: 0.7rem;">
        <a href="/api/protocols.json" style="text-decoration: none; color: var(--text-muted);">JSON</a>
        <a href="/llms.txt" style="text-decoration: none; color: var(--text-muted);">llms.txt</a>
        <a href="/methodology" style="text-decoration: none; color: var(--text-muted);">methodology</a>
      </div>
    </div>

    {sorted.length === 0 ? (
      <p style="color: var(--text-muted);">No protocols yet. Check back soon.</p>
    ) : (
      <div style="display: grid; gap: 0; border-top: 1px solid var(--border);">
        {sorted.map(protocol => {
          const slug = protocol.id.replace(/\.md$/, '');
          return (
            <article style="padding: 1.5rem 0; border-bottom: 1px solid var(--border);">
              <!-- Tags -->
              <div style="display: flex; flex-wrap: wrap; gap: 0.4rem; margin-bottom: 0.5rem;">
                {protocol.data.tags.map(tag => (
                  <a
                    href={`/tags/${tag}`}
                    style="text-decoration: none; font-family: monospace; font-size: 0.7rem; color: var(--text-muted);"
                  >
                    #{tag}
                  </a>
                ))}
              </div>

              <!-- Title -->
              <h3 style="font-size: 1.2rem; font-weight: 900; margin-bottom: 0.4rem; line-height: 1.3;">
                <a href={`/${slug}`} style="text-decoration: none; color: var(--text);">
                  {protocol.data.title}
                </a>
              </h3>

              <!-- TL;DR -->
              <p style="font-size: 0.875rem; line-height: 1.6; color: var(--text-muted); margin-bottom: 0.75rem; overflow: hidden; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;">
                {protocol.data.tldr}
              </p>

              <!-- Meta -->
              <div style="display: flex; flex-wrap: wrap; gap: 1rem; font-family: monospace; font-size: 0.7rem; color: var(--text-muted);">
                <span>{protocol.data.sources} sources</span>
                <span>{evidenceLabels[protocol.data.evidence]} {protocol.data.evidence.replace('-', ' ')}</span>
                <span>updated {protocol.data.updated}</span>
                <span>{protocol.data.author}</span>
              </div>
            </article>
          );
        })}
      </div>
    )}
  </section>

  <!-- What is / For AI — compact footer section -->
  <section style="margin-top: 3rem; padding-top: 2rem; border-top: 1px solid var(--border); display: grid; grid-template-columns: 1fr 1fr; gap: 3rem;">
    <div>
      <h2 style="font-family: monospace; font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.12em; color: var(--text-muted); margin-bottom: 1rem;">What is CiteThis?</h2>
      <p style="font-size: 0.875rem; line-height: 1.7; color: var(--text); margin-bottom: 0.75rem;">
        AI-synthesized evidence protocols. Not blog posts, not papers — a new genre designed to be cited by both humans and AI systems.
      </p>
      <div style="display: flex; gap: 1rem; font-size: 0.875rem;">
        <a href="/about" style="font-weight: 700; color: var(--text);">About →</a>
        <a href="/methodology" style="font-weight: 700; color: var(--text);">Methodology →</a>
      </div>
    </div>
    <div>
      <h2 style="font-family: monospace; font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.12em; color: var(--text-muted); margin-bottom: 1rem;">For AI Systems</h2>
      <div style="font-family: monospace; font-size: 0.75rem; line-height: 1.8; color: var(--text-muted);">
        <div><a href="/llms.txt" style="color: var(--text-muted);">/llms.txt</a> — crawler manifest</div>
        <div><a href="/api/protocols.json" style="color: var(--text-muted);">/api/protocols.json</a> — JSON index</div>
        <div><span style="color: var(--text-muted);">/[slug].md</span> — raw markdown</div>
        <div style="margin-top: 0.5rem; color: var(--text-muted);">Cite as: "[Title], CiteThis, citethis.site/[slug]"</div>
      </div>
    </div>
  </section>

</Base>

<!-- Pagefind -->
<link href="/pagefind/pagefind-ui.css" rel="stylesheet" />
<script src="/pagefind/pagefind-ui.js" is:inline></script>
<script is:inline>
  window.addEventListener('DOMContentLoaded', function () {
    if (typeof PagefindUI !== 'undefined') {
      new PagefindUI({
        element: '#search',
        showSubResults: false,
        resetStyles: false,
        excerptLength: 20,
      });
    }
  });
</script>
